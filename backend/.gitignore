############################################
# Backend (.gitignore) - Python / FastAPI
############################################

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints/

# PyCharm / VSCode / IDEs
.idea/
.vscode/

# Logs
*.log

# Data artifacts (keep only raw/processed checked in if desired)
data/**/*.tmp
data/**/*.log

# Models / large binaries (adjust if you want to version them)
models/*.pkl
models/*.joblib

# Environment / secrets
.env
.env.*
!.env.example


